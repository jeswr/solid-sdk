{
  "name": "@jeswr/federation-codegen",
  "version": "0.0.0",
  "private": true,
  "description": "Proof-of-concept generator for typed @rdfjs/wrapper models from federation ontology and SHACL inputs",
  "type": "module",
  "license": "MIT",
  "author": "Jesse Wright <63333554+jeswr@users.noreply.github.com>",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc -p generated/bookmarks-sector/tsconfig.json",
    "generate:bookmarks": "node src/cli.ts --ontology ../../packages/solid-federation-vocab/sectors/bookmarks/bookmarks.ttl --shapes ../../packages/solid-federation-vocab/sectors/bookmarks/bookmarks.shacl.ttl --out generated/bookmarks-sector --package-name @jeswr/generated-bookmarks-sector-model",
    "lint": "biome check src test generated",
    "typecheck": "tsc --noEmit && tsc -p generated/bookmarks-sector/tsconfig.json --noEmit",
    "test": "vitest run",
    "gate": "pnpm run lint && pnpm run build && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@rdfjs/wrapper": "^0.34.0",
    "n3": "^2.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@rdfjs/types": "^2.0.1",
    "@types/n3": "^1.26.1",
    "@types/node": "^25.9.2",
    "@zazuko/env-node": "^3.0.0",
    "rdf-validate-shacl": "^0.6.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
