<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<!-- OASIS XML catalog for the scheduling sector's owl:imports closure, for the
     ROBOT/HermiT consistency gate (scripts/ontology-gate.mjs F6). Maps every
     import IRI to a local Turtle file so no network dereference is needed. -->
<catalog prefer="public" xmlns="urn:oasis:names:tc:entity:xmlns:xml:catalog">
  <!-- gUFO (the adopted foundation) -->
  <uri name="http://purl.org/nemo/gufo#" uri="../core/imports/gufo.ttl"/>
  <uri name="http://purl.org/nemo/gufo" uri="../core/imports/gufo.ttl"/>
  <uri name="http://purl.org/nemo/gufo#/1.0.0" uri="../core/imports/gufo.ttl"/>
  <!-- W3C OWL-Time -->
  <uri name="http://www.w3.org/2006/time" uri="../core/imports/owl-time.ttl"/>
  <uri name="http://www.w3.org/2006/time#" uri="../core/imports/owl-time.ttl"/>
  <!-- PROV-O -->
  <uri name="http://www.w3.org/ns/prov-o" uri="../core/imports/prov-o.ttl"/>
  <uri name="http://www.w3.org/ns/prov#" uri="../core/imports/prov-o.ttl"/>
  <uri name="http://www.w3.org/ns/prov" uri="../core/imports/prov-o.ttl"/>
  <!-- SKOS Core -->
  <uri name="http://www.w3.org/2004/02/skos/core" uri="../core/imports/skos.ttl"/>
  <uri name="http://www.w3.org/2004/02/skos/core#" uri="../core/imports/skos.ttl"/>
  <!-- QUDT schema + slim units -->
  <uri name="http://qudt.org/schema/qudt/" uri="../core/imports/qudt-schema.ttl"/>
  <uri name="http://qudt.org/2.1/schema/qudt" uri="../core/imports/qudt-schema.ttl"/>
  <uri name="http://qudt.org/2.1/vocab/qudt-slim" uri="../core/imports/qudt-units-slim.ttl"/>
  <!-- The Solid Core (the sector's mandatory import) -->
  <uri name="https://w3id.org/jeswr/core" uri="../core/core.ttl"/>
  <uri name="https://w3id.org/jeswr/core#" uri="../core/core.ttl"/>
  <uri name="https://w3id.org/jeswr/core/1.0.1" uri="../core/core.ttl"/>
  <!-- This sector (self, for the alignments file's import) -->
  <uri name="https://w3id.org/jeswr/sectors/scheduling" uri="scheduling.ttl"/>
  <uri name="https://w3id.org/jeswr/sectors/scheduling#" uri="scheduling.ttl"/>
  <uri name="https://w3id.org/jeswr/sectors/scheduling/1.0.0" uri="scheduling.ttl"/>
</catalog>
