# AUTHORED-BY Claude Opus 4.8 (Fable unavailable) — re-review/upgrade candidate
#
@prefix drawing: <https://w3id.org/jeswr/sectors/drawing#> .
@prefix core:    <https://w3id.org/jeswr/core#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix schema:  <http://schema.org/> .
# The forthcoming detailed drawing vocabulary (ships in @jeswr/solid-drawing).
@prefix draw:    <https://w3id.org/jeswr/drawing#> .

# =============================================================================
# Drawing Sector Ontology — ALIGNMENTS (Mode A: annotation-only bridges)
#
# Annotation-only (skos:*Match) bridges to (a) the FORTHCOMING detailed draw:
# vocabulary in the separate @jeswr/solid-drawing repo and (b) schema.org. NO
# entailment — data authored against draw: / schema.org is recognised without
# inheriting any axioms, and importing this file never changes the reasoned
# closure's consistency. The HOOK to draw: is deliberately Mode A so this sector
# can be authored + shipped now without forward-referencing an unpublished
# ontology in its owl:imports closure (Phase B publishes draw: in its own repo).
# Every line is a reviewable claim; nothing is silently inherited.
# =============================================================================

<https://w3id.org/jeswr/sectors/drawing/alignments> a owl:Ontology ;
    dcterms:title "Solid Drawing Sector Ontology — draw: + schema.org Mode-A alignments"@en ;
    owl:imports <https://w3id.org/jeswr/sectors/drawing> ;
    rdfs:comment "Annotation-only (skos:*Match) bridges to the forthcoming @jeswr/solid-drawing draw: vocabulary and to schema.org. No entailment. "@en .

# --- Scene <-> draw:Scene (the forthcoming detail vocab) + schema:CreativeWork ---
# draw:Scene rdfs:subClassOf schema:CreativeWork ships in @jeswr/solid-drawing;
# here the sector's Scene closeMatches it, and exactMatches the schema.org root it
# specialises. closeMatch (not exact) to draw:Scene: the detail vocab may carry
# element-level structure this thin sector class does not.
drawing:Scene          skos:closeMatch draw:Scene ;
                       skos:exactMatch schema:CreativeWork .

# --- the round-trip properties <-> the forthcoming draw: terms + schema.org ---
drawing:sceneDocument  skos:closeMatch draw:sceneDocument .
drawing:schemaVersion  skos:closeMatch draw:schemaVersion ;
                       skos:closeMatch schema:schemaVersion .
drawing:thumbnail      skos:closeMatch draw:thumbnail ;
                       skos:closeMatch schema:thumbnailUrl .
