    rdfs:label "كتلة"@ar,
        "Маса"@bg,
        "Hmotnost"@cs,
        "Masse"@de,
        "Μάζα"@el,
        "Mass"@en,
        "masa"@es,
        "جرم"@fa,
        "masse"@fr,
        "מסה"@he,
        "भार"@hi,
        "tömeg"@hu,
        "massa"@it,
        "質量"@ja,
        "massa"@la,
        "Jisim"@ms,
