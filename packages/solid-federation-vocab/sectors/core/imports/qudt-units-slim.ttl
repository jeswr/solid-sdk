quantitykind:Time a qudt:QuantityKind ;
    rdfs:label "زمن"@ar,
        "Време"@bg,
        "Čas"@cs,
        "Zeit"@de,
        "Χρόνος"@el,
        "Time"@en,
        "tiempo"@es,
        "زمان"@fa,
        "temps"@fr,
        "זמן"@he,
        "समय"@hi,
        "idő"@hu,
        "tempo"@it,
        "時間"@ja,
        "tempus"@la,
        "Masa"@ms,
        "czas"@pl,
        "tempo"@pt,
        "timp"@ro,
        "Время"@ru,
        "čas"@sl,
        "zaman"@tr,
        "时间"@zh ;
    dcterms:description """Time is a basic component of the measuring system used to sequence events, to compare the durations of
