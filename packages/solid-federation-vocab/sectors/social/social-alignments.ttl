# AUTHORED-BY Claude Opus 4.8 (Fable unavailable) — re-review/upgrade candidate
#
@prefix social:  <https://w3id.org/jeswr/sectors/social#> .
@prefix core:    <https://w3id.org/jeswr/core#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
# ActivityStreams 2.0 + SIOC + schema.org — the reused content model.
# IRIs verified against @jeswr/solid-chat-interop's vocab.ts (the suite's
# canonical AS2 write shape): AS = https://www.w3.org/ns/activitystreams# ,
# SIOC = http://rdfs.org/sioc/ns# .
@prefix as:      <https://www.w3.org/ns/activitystreams#> .
@prefix sioc:    <http://rdfs.org/sioc/ns#> .
@prefix schema:  <http://schema.org/> .

# =============================================================================
# Social Sector Ontology — ALIGNMENTS (Mode A: annotation-only bridges)
#
# Annotation-only (skos:*Match) bridges to ActivityStreams 2.0, SIOC and
# schema.org — the content model @jeswr/solid-chat-interop's CanonicalMessage
# already serialises (its content model IS AS2). NO entailment — data authored as
# as:Note / sioc:Note is recognised without inheriting any AS2 axioms, and
# importing this file never changes the reasoned closure's consistency. Every line
# is a reviewable claim; nothing is silently inherited.
#
# This is the seam that makes the social sector a thin DOMAIN MARKER over the
# reused AS2 vocabulary rather than a fork of it: an Elk/Miniflux fork writes AS2,
# pod-chat writes AS2, and these bridges let the federation recognise both as the
# same social:Note shape chat-interop reconciles.
# =============================================================================

<https://w3id.org/jeswr/sectors/social/alignments> a owl:Ontology ;
    dcterms:title "Solid Social Sector Ontology — AS2 + SIOC + schema.org Mode-A alignments"@en ;
    owl:imports <https://w3id.org/jeswr/sectors/social> ;
    rdfs:comment "Annotation-only (skos:*Match) bridges to ActivityStreams 2.0, SIOC and schema.org — the @jeswr/solid-chat-interop CanonicalMessage content model. No entailment. "@en .

# --- Note <-> as:Note / sioc:Note (the canonical message/feed-item shape) ---
social:Note          skos:exactMatch as:Note ;
                     skos:closeMatch sioc:Note ;
                     skos:closeMatch schema:SocialMediaPosting .

# --- Feed <-> as:Collection (timeline / room / RSS feed) ---
social:Feed          skos:exactMatch as:Collection ;
                     skos:closeMatch sioc:Container .

# --- the round-trip properties <-> AS2 / SIOC / dct ---
social:content       skos:exactMatch as:content ;
                     skos:closeMatch sioc:content .
social:mediaType     skos:exactMatch as:mediaType .
social:attributedTo  skos:exactMatch as:attributedTo .
social:published     skos:exactMatch as:published ;
                     skos:closeMatch dcterms:created .
# inReplyTo is the AS2 direction ONLY (never the inverse sioc:has_reply), matching
# chat-interop's reply-edge discipline.
social:inReplyTo     skos:exactMatch as:inReplyTo .
social:inFeed        skos:closeMatch as:context .
