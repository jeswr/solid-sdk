{
  "@context": {
    "@version": 1.1,
    "@protected": true,
    "fin": "https://w3id.org/jeswr/sectors/finance#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "id": "@id",
    "type": "@type",
    "AccountCustodian": "fin:AccountCustodian",
    "ActiveFinancialAccount": "fin:ActiveFinancialAccount",
    "allocated": {
      "@id": "fin:allocated",
      "@type": "@id"
    },
    "amount": {
      "@id": "fin:amount",
      "@type": "xsd:decimal"
    },
    "Balance": "fin:Balance",
    "Bank": "fin:Bank",
    "Budget": "fin:Budget",
    "BudgetCategory": "fin:BudgetCategory",
    "CardPayment": "fin:CardPayment",
    "categoryConcept": {
      "@id": "fin:categoryConcept",
      "@type": "@id"
    },
    "ClosedFinancialAccount": "fin:ClosedFinancialAccount",
    "Counterparty": "fin:Counterparty",
    "creditAccount": {
      "@id": "fin:creditAccount",
      "@type": "@id"
    },
    "CreditAccount": "fin:CreditAccount",
    "currency": {
      "@id": "fin:currency",
      "@type": "xsd:string"
    },
    "CurrentAccount": "fin:CurrentAccount",
    "debitAccount": {
      "@id": "fin:debitAccount",
      "@type": "@id"
    },
    "FinancialAccount": "fin:FinancialAccount",
    "FinancialInstitution": "fin:FinancialInstitution",
    "FinancialInstrument": "fin:FinancialInstrument",
    "FrozenFinancialAccount": "fin:FrozenFinancialAccount",
    "hasCategory": {
      "@id": "fin:hasCategory",
      "@type": "@id"
    },
    "hasCounterparty": {
      "@id": "fin:hasCounterparty",
      "@type": "@id"
    },
    "hasMonetaryAmount": {
      "@id": "fin:hasMonetaryAmount",
      "@type": "@id"
    },
    "heldInAccount": {
      "@id": "fin:heldInAccount",
      "@type": "@id"
    },
    "Holding": "fin:Holding",
    "inCategory": {
      "@id": "fin:inCategory",
      "@type": "@id"
    },
    "InvestmentAccount": "fin:InvestmentAccount",
    "MonetaryAmount": "fin:MonetaryAmount",
    "ofInstrument": {
      "@id": "fin:ofInstrument",
      "@type": "@id"
    },
    "payee": {
      "@id": "fin:payee",
      "@type": "@id"
    },
    "Payee": "fin:Payee",
    "payer": {
      "@id": "fin:payer",
      "@type": "@id"
    },
    "Payer": "fin:Payer",
    "Payment": "fin:Payment",
    "postingTime": {
      "@id": "fin:postingTime",
      "@type": "xsd:dateTime"
    },
    "quantity": {
      "@id": "fin:quantity",
      "@type": "xsd:decimal"
    },
    "SavingsAccount": "fin:SavingsAccount",
    "sector": "fin:sector",
    "Security": "fin:Security",
    "snapshot": {
      "@id": "fin:snapshot",
      "@type": "@id"
    },
    "syncLog": {
      "@id": "fin:syncLog",
      "@type": "@id"
    },
    "Transaction": "fin:Transaction",
    "TransactionRecord": "fin:TransactionRecord",
    "Transfer": "fin:Transfer"
  }
}
