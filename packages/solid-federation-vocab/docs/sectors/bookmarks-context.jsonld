{
  "@context": {
    "@version": 1.1,
    "@protected": true,
    "bookmark": "https://w3id.org/jeswr/sectors/bookmarks#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "id": "@id",
    "type": "@type",
    "archived": {
      "@id": "bookmark:archived",
      "@type": "xsd:boolean"
    },
    "Bookmark": "bookmark:Bookmark",
    "hasTag": {
      "@id": "bookmark:hasTag",
      "@type": "@id"
    },
    "notes": {
      "@id": "bookmark:notes",
      "@type": "xsd:string"
    },
    "sector": "bookmark:sector"
  }
}
