{
  "name": "@jeswr/federation-registry",
  "version": "0.1.0",
  "description": "Typed TypeScript client for the Solid Federation Catalogue / Registry vocabulary (fedreg:) at https://w3id.org/jeswr/fedreg#. Build/parse/verify a registry of registry-asserted memberships, and storage-description spec-version advertisements for schema-migration coordination. Experimental, AI-agent-generated.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build:deps": "node scripts/build-deps.mjs",
    "build": "node scripts/build-dist.mjs",
    "build:dev": "npm run build:deps && tsc -p tsconfig.json",
    "check:dist": "node scripts/check-dist-fresh.mjs",
    "check:lockfile-transport": "node scripts/check-lockfile-transport.mjs",
    "typecheck": "npm run build:deps && tsc -p tsconfig.json --noEmit",
    "lint": "biome check src test scripts && npm run check:lockfile-transport",
    "lint:fix": "biome check --write src test scripts",
    "test": "npm run build:deps && vitest run",
    "test:coverage": "npm run build:deps && vitest run --coverage",
    "prepare": "npm run build"
  },
  "keywords": [
    "solid",
    "federation",
    "fedreg",
    "registry",
    "catalogue",
    "dcat",
    "membership",
    "schema-migration",
    "rdf",
    "linked-data"
  ],
  "author": "Jesse Wright <jwrightwho@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeswr/federation-registry.git"
  },
  "bugs": {
    "url": "https://github.com/jeswr/federation-registry/issues"
  },
  "homepage": "https://github.com/jeswr/federation-registry#readme",
  "dependencies": {
    "@rdfjs/types": "^2.0.1",
    "@rdfjs/wrapper": "^0.34.0",
    "content-type": "^1.0.5",
    "jsonld-streaming-parser": "^5.0.0",
    "n3": "^2.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@jeswr/fetch-rdf": "github:jeswr/fetch-rdf#main",
    "@types/n3": "^1.16.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
