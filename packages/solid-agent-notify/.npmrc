# Disable package install/lifecycle scripts on `npm install` / `npm ci`.
#
# Supply-chain hardening (suite-wide policy): defends against malware that ships
# its payload in a postinstall / preinstall / prepare script that runs the moment
# the package is fetched (event-stream/flatmap-stream 2018, Shai-Hulud 2025-09).
#
# Note: this package's own `prepare` build (tsc → dist/) is what produces the
# published/git-dep artifacts; with ignore-scripts=true a consumer installing the
# git dependency must build explicitly. Published npm tarballs already ship dist/,
# so the common `npm install solid-agent-notify` path is unaffected.
ignore-scripts=true
