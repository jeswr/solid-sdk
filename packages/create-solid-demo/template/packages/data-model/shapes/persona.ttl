# The demo persona's SHACL shape: drives deterministic synthetic data
# (@jeswr/synthetic-rdf) and validates every seeded persona resource.
# Only real namespaces + a urn:example: local shape identity (no minted IRIs).
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix schema: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<urn:example:shape:persona> a sh:NodeShape ;
  sh:targetClass schema:Person ;
  sh:property [
    sh:path schema:name ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:pattern "^[A-Z][a-z]+ [A-Z][a-z]+$" ;
  ] ;
  sh:property [
    sh:path schema:identifier ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:in ( "AS-0001" ) ;
  ] .
