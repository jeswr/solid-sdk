# AUTHORED-BY Claude Opus 4.8 (Fable unavailable) — re-review/upgrade candidate
#
# SHACL shape for a drawing scene descriptor (@jeswr/solid-drawing).
#
# The contract a `draw:Scene` must satisfy so any suite app can list, render and
# round-trip it. Authored against the minted draw: terms plus the re-used,
# dereferenceable standard IRIs only (Dublin Core Terms, schema.org, PROV-O).
#
# The shape is ANONYMOUS (a blank node), so this file mints nothing at a
# non-resolving domain — it is purely a validation contract. Validate a scene
# descriptor's typed-accessor output before write, and on read of untrusted data
# (rdf-validate-shacl; see src/scene.test.ts).
#
# The core invariant: a scene MUST point at exactly one canvas resource
# (draw:sceneDocument, an IRI) — a scene without its byte-exact .excalidraw blob is
# not a scene. Everything else is optional metadata, each at most one value.

@prefix sh:     <http://www.w3.org/ns/shacl#> .
@prefix draw:   <https://w3id.org/jeswr/drawing#> .
@prefix dct:    <http://purl.org/dc/terms/> .
@prefix schema: <http://schema.org/> .
@prefix prov:   <http://www.w3.org/ns/prov#> .
@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .

# --- A drawing scene (draw:Scene) ---
[] a sh:NodeShape ;
  sh:targetClass draw:Scene ;

  # The canvas link — REQUIRED, exactly one IRI. A scene without its byte-exact
  # .excalidraw JSON resource is not a valid scene.
  sh:property [
    sh:path draw:sceneDocument ; sh:name "scene document" ;
    sh:nodeKind sh:IRI ; sh:minCount 1 ; sh:maxCount 1 ;
  ] ;

  # Title — at most one string.
  sh:property [
    sh:path dct:title ; sh:name "title" ;
    sh:datatype xsd:string ; sh:maxCount 1 ;
  ] ;

  # Timestamps — xsd:dateTime, at most one each.
  sh:property [
    sh:path dct:created ; sh:name "created" ;
    sh:datatype xsd:dateTime ; sh:maxCount 1 ;
  ] ;
  sh:property [
    sh:path dct:modified ; sh:name "modified" ;
    sh:datatype xsd:dateTime ; sh:maxCount 1 ;
  ] ;

  # Excalidraw scene-format version — a literal, at most one.
  sh:property [
    sh:path draw:schemaVersion ; sh:name "schema version" ;
    sh:nodeKind sh:Literal ; sh:maxCount 1 ;
  ] ;

  # Canvas background colour — a literal, at most one.
  sh:property [
    sh:path draw:viewBackgroundColor ; sh:name "view background colour" ;
    sh:nodeKind sh:Literal ; sh:maxCount 1 ;
  ] ;

  # Thumbnail image — an IRI, at most one.
  sh:property [
    sh:path draw:thumbnail ; sh:name "thumbnail" ;
    sh:nodeKind sh:IRI ; sh:maxCount 1 ;
  ] ;

  # Subject the drawing is about — an IRI, at most one.
  sh:property [
    sh:path schema:about ; sh:name "about" ;
    sh:nodeKind sh:IRI ; sh:maxCount 1 ;
  ] ;

  # Provenance — an IRI, at most one.
  sh:property [
    sh:path prov:wasGeneratedBy ; sh:name "was generated by" ;
    sh:nodeKind sh:IRI ; sh:maxCount 1 ;
  ] .
