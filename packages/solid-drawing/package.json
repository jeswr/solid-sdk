{
  "name": "@jeswr/solid-drawing",
  "version": "0.1.0",
  "description": "RDF vocabulary + typed term constants for vector drawings / whiteboards — the data model for an Excalidraw→Solid fork (a draw:Scene points at a byte-exact .excalidraw JSON blob; the canvas is NOT shredded into triples). Ships the ontology TTL, a SHACL shape, and a committed self-contained dist/.",
  "type": "module",
  "license": "MIT",
  "author": "Jesse Wright",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeswr/solid-drawing.git"
  },
  "homepage": "https://github.com/jeswr/solid-drawing#readme",
  "bugs": {
    "url": "https://github.com/jeswr/solid-drawing/issues"
  },
  "keywords": [
    "solid",
    "rdf",
    "drawing",
    "whiteboard",
    "excalidraw",
    "vocabulary",
    "ontology",
    "shacl"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vocab": {
      "types": "./dist/vocab.d.ts",
      "import": "./dist/vocab.js"
    },
    "./shape": {
      "types": "./dist/shape.d.ts",
      "import": "./dist/shape.js"
    },
    "./scene": {
      "types": "./dist/scene.d.ts",
      "import": "./dist/scene.js"
    },
    "./drawing.ttl": "./drawing.ttl",
    "./drawing.shacl.ttl": "./drawing.shacl.ttl"
  },
  "files": [
    "dist",
    "drawing.ttl",
    "drawing.shacl.ttl",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@jeswr/fetch-rdf": "^0.1.0",
    "@rdfjs/wrapper": "^0.34.0",
    "n3": "^2.0.3"
  },
  "peerDependencies": {
    "@rdfjs/types": "^2.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@rdfjs/types": "^2.0.1",
    "@types/n3": "^1.26.1",
    "@types/node": "^20",
    "@zazuko/env-node": "^3.0.0",
    "rdf-validate-shacl": "^0.6.5",
    "typescript": "^5",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20"
  }
}
