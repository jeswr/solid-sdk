# Disable package install/lifecycle scripts on `npm install` / `npm ci`
# (supply-chain hardening — house rule across the solid-app-suite).
#
# Defends against a class of supply-chain malware that ships its payload in a
# postinstall / preinstall / prepare script that runs the moment the package is
# fetched (event-stream/flatmap-stream 2018, Shai-Hulud 2025-09).
#
# If a future bump introduces a dep that genuinely needs its install script to
# function, the failure is loud (the dep breaks at import) and the remediation is
# `npm rebuild --foreground-scripts <name>` in a controlled, reviewed step — not
# to lift this default.
ignore-scripts=true
