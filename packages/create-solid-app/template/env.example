# Copy to .env.local for local development.

# Local dev pod (Community Solid Server) base URL. The dev script seeds accounts here.
NEXT_PUBLIC_DEV_POD=http://localhost:3000

# Dev-only: allow interactive login against an HTTP/loopback issuer (local CSS).
# MUST be "true" for the local dev pod to log in; leave UNSET in production —
# remote pods use HTTPS issuers and stay strict.
NEXT_PUBLIC_ALLOW_INSECURE_LOOPBACK=true
