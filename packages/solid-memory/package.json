{
  "name": "@jeswr/solid-memory",
  "version": "0.1.0",
  "description": "A typed RDF agent-memory model + Solid-pod store + client-side search — the user-owned, portable, cross-agent AI-memory aggregator core (mem:MemoryItem reusing schema.org / Dublin Core / PROV-O / ActivityStreams), so a memory written by one agent is readable + searchable by another.",
  "type": "module",
  "license": "MIT",
  "author": "Jesse Wright",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeswr/solid-memory.git"
  },
  "homepage": "https://github.com/jeswr/solid-memory#readme",
  "bugs": {
    "url": "https://github.com/jeswr/solid-memory/issues"
  },
  "keywords": [
    "solid",
    "rdf",
    "memory",
    "agent",
    "ai",
    "federation"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./memory": {
      "types": "./dist/memory.d.ts",
      "import": "./dist/memory.js"
    },
    "./store": {
      "types": "./dist/store.d.ts",
      "import": "./dist/store.js"
    },
    "./search": {
      "types": "./dist/search.d.ts",
      "import": "./dist/search.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "api:report": "npm run build && npx --yes @microsoft/api-extractor@7 run --local",
    "api:check": "npm run build && npx --yes @microsoft/api-extractor@7 run"
  },
  "dependencies": {
    "@jeswr/fetch-rdf": "^0.1.0",
    "@jeswr/rdf-serialize": "workspace:*",
    "@rdfjs/wrapper": "^0.34.0",
    "@solid/object": "^0.6.0",
    "n3": "^2.0.3"
  },
  "peerDependencies": {
    "@rdfjs/types": "^2.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@rdfjs/types": "^2.0.1",
    "@types/n3": "^1.26.1",
    "@types/node": "^20",
    "typescript": "^5",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20"
  }
}
