# Supply-chain hardening (suite default, mirrors prod-solid-server ADR-0011):
# no npm lifecycle hook runs on install. Defends against malware shipping its
# payload in a postinstall/preinstall/prepare hook. If a dep genuinely needs an
# install script the failure is loud (breaks at import) and the fix is a
# controlled, reviewed `npm rebuild --foreground-scripts <name>` — never lifting
# this default.
ignore-scripts=true
