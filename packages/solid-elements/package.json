{
  "name": "@jeswr/solid-elements",
  "version": "0.1.0",
  "securityCritical": true,
  "description": "Framework-agnostic W3C Web Components (Lit 3) for the Solid app suite — presentation-only chrome (theme toggle, account menu, feedback button, empty/error/loading states) that inherits the @jeswr/app-shell OKLCH theme through CSS custom properties. Includes ergonomic React (@lit/react) wrappers.",
  "author": "Claude Opus 4.8 (@jeswr PSS agent)",
  "license": "MIT",
  "type": "module",
  "customElements": "custom-elements.json",
  "sideEffects": [
    "./dist/index.js",
    "./dist/components/*.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "custom-elements.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "biome check src test scripts && npm run check:manifest",
    "lint:fix": "biome check --write src test scripts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && npm run check:manifest",
    "manifest": "cem analyze",
    "check:manifest": "node scripts/check-manifest.mjs",
    "api:report": "node scripts/api-report.mjs --local",
    "api:check": "node scripts/api-report.mjs"
  },
  "peerDependencies": {
    "@jeswr/fetch-rdf": "^0.1.0",
    "@jeswr/solid-session-restore": "workspace:*",
    "@solid/object": "^0.6.0",
    "@solid/reactive-authentication": "^0.1.3",
    "dpop": "^2.1.1",
    "n3": "^1.17.0 || ^2.0.0",
    "oauth4webapi": "^3.8.6",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "@jeswr/fetch-rdf": {
      "optional": true
    },
    "@jeswr/solid-session-restore": {
      "optional": true
    },
    "@solid/object": {
      "optional": true
    },
    "@solid/reactive-authentication": {
      "optional": true
    },
    "dpop": {
      "optional": true
    },
    "n3": {
      "optional": true
    },
    "oauth4webapi": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@lit/react": "^1.0.8",
    "lit": "^3.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@jeswr/fetch-rdf": "^0.1.0",
    "@jeswr/solid-session-restore": "workspace:*",
    "@solid/object": "^0.6.0",
    "@solid/reactive-authentication": "^0.1.3",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/n3": "^1.26.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "comment-parser": "^1.2.4",
    "dpop": "^2.1.1",
    "jsdom": "^26.1.0",
    "n3": "^1.17.0",
    "oauth4webapi": "^3.8.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.8"
  }
}
