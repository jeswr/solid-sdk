{
  "name": "@jeswr/solid-elements",
  "version": "0.1.0",
  "description": "Framework-agnostic W3C Web Components (Lit 3) for the Solid app suite — presentation-only chrome (theme toggle, account menu, feedback button, empty/error/loading states) that inherits the @jeswr/app-shell OKLCH theme through CSS custom properties. Includes ergonomic React (@lit/react) wrappers.",
  "author": "Claude Opus 4.8 (@jeswr PSS agent)",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "./dist/index.js",
    "./dist/components/*.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "biome check src test scripts",
    "lint:fix": "biome check --write src test scripts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check:dist": "node scripts/check-dist.mjs",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@lit/react": "^1.0.8",
    "lit": "^3.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^26.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.8"
  }
}
