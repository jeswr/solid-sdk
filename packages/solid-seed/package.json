{
  "name": "@jeswr/solid-seed",
  "version": "0.1.0",
  "securityCritical": true,
  "description": "Browser-safe, server-agnostic provisioning and deterministic pod seeding for @jeswr/synthetic-rdf output.",
  "type": "module",
  "license": "MIT",
  "author": "Jesse Wright <63333554+jeswr@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeswr/solid-sdk.git",
    "directory": "packages/solid-seed"
  },
  "homepage": "https://github.com/jeswr/solid-sdk/tree/main/packages/solid-seed#readme",
  "bugs": {
    "url": "https://github.com/jeswr/solid-sdk/issues"
  },
  "keywords": [
    "solid",
    "rdf",
    "rdfjs",
    "seed",
    "fixtures",
    "wac"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "SKILL.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "node scripts/check-browser-safe.mjs && biome check src test scripts",
    "lint:fix": "biome check --write src test scripts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@jeswr/rdf-serialize": "workspace:*",
    "@jeswr/synthetic-rdf": "workspace:*",
    "@rdfjs/types": "^2.0.1",
    "@solid/object": "^0.6.0",
    "n3": "2.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@jeswr/solid-server": "file:vendor/jeswr-solid-server-0.1.0.tgz",
    "@types/n3": "^1.26.1",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  }
}
