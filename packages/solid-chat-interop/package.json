{
  "name": "@jeswr/solid-chat-interop",
  "version": "0.0.1",
  "description": "Chat/conversation interop reconciler — maps between ActivityStreams 2.0 (the suite's canonical chat write model), SolidOS meeting:LongChat (the installed-base read), and an external-schema adapter seam (LibreChat as proof). Pure-RDF, non-server-touching, typed accessors only.",
  "type": "module",
  "license": "MIT",
  "author": "Jesse Wright",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jeswr/solid-chat-interop.git"
  },
  "homepage": "https://github.com/jeswr/solid-chat-interop#readme",
  "bugs": {
    "url": "https://github.com/jeswr/solid-chat-interop/issues"
  },
  "keywords": [
    "solid",
    "rdf",
    "chat",
    "activitystreams",
    "as2",
    "longchat",
    "solidos",
    "librechat",
    "interop",
    "reconciler"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapter": {
      "types": "./dist/adapter.d.ts",
      "import": "./dist/adapter.js"
    },
    "./shape": {
      "types": "./dist/shape.d.ts",
      "import": "./dist/shape.js"
    },
    "./shapes/message.shacl.ttl": "./shapes/message.shacl.ttl"
  },
  "files": [
    "dist",
    "shapes",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gate": "npm run lint && npm run typecheck && npm run test && npm run build && npm run check:dist && npm run check:lockfile-transport",
    "check:dist": "node scripts/check-dist.mjs",
    "check:lockfile-transport": "node scripts/check-lockfile-transport.mjs"
  },
  "dependencies": {
    "@jeswr/fetch-rdf": "^0.1.0",
    "@jeswr/solid-task-model": "git+https://github.com/jeswr/solid-task-model.git#fa88a345a5ed03b26b46efd57d448ebd9ca8a826",
    "@rdfjs/wrapper": "^0.34.0",
    "n3": "^2.0.3"
  },
  "peerDependencies": {
    "@rdfjs/types": "^2.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@rdfjs/types": "^2.0.1",
    "@types/n3": "^1.26.1",
    "@types/node": "^20",
    "@zazuko/env-node": "^3.0.0",
    "rdf-validate-shacl": "^0.6.5",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
