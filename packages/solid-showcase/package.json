{
  "name": "@jeswr/solid-showcase",
  "version": "0.1.0",
  "description": "JSON-driven walkthrough site for Solid concept demos — a zod-validated walkthrough document schema, four page renderers and the walkthrough UI components, plus document-consuming deploy helpers under ./next.",
  "author": "Claude Fable 5 (@jeswr solid-sdk agent)",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js"
    },
    "./schema/walkthrough.v1.json": "./schema/walkthrough.v1.json"
  },
  "files": [
    "dist",
    "src",
    "schema",
    "README.md",
    "SKILL.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "generate:schema": "node scripts/generate-schema.mjs",
    "lint": "biome check src test scripts",
    "lint:fix": "biome check --write src test scripts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@jeswr/app-shell": "workspace:*",
    "@jeswr/solid-showcase-kit": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "jsdom": "^26.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
