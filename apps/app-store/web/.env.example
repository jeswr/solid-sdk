# Copy to .env / .env.local. These drive the build-time clientid/callback + catalog
# generation AND the runtime SessionProvider.

# The deployment origin. The Client Identifier Document + callback.html
# (scripts/gen-clientid.mjs) AND the DCAT catalog IRIs (scripts/gen-catalog.mjs) are
# generated from this, and the reactive-auth client_id resolves to
# ${APP_ORIGIN}/clientid.jsonld at runtime. Default (unset): http://localhost:5173.
# Production:
#   APP_ORIGIN=https://apps.solid-test.jeswr.org
APP_ORIGIN=http://localhost:5173

# Mirror of APP_ORIGIN exposed to the client bundle (Vite only inlines VITE_*).
# Keep equal to APP_ORIGIN. Non-load-bearing for auth (the client_id is derived from
# the actual window origin at runtime); used only for UI labelling.
VITE_APP_ORIGIN=http://localhost:5173

# The suite's HOME identity provider (Solid-OIDC issuer), shown as a hint in the
# sign-in dialog. The auth issuer always comes from the WebID profile, so this is a
# display hint only.
VITE_HOME_IDP=https://idp.solid-test.jeswr.org
