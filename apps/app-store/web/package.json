{
  "name": "@jeswr/solid-app-store-web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Static SPA for the Solid App Store — a discover-and-launch hub for the Solid app suite, with a DCAT/schema.org Linked Data catalog and token-free silent-SSO launch links.",
  "author": "Claude Opus 4.8 (@jeswr PSS agent)",
  "license": "MIT",
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "gen:clientid": "node scripts/gen-clientid.mjs",
    "gen:catalog": "node scripts/gen-catalog.mjs",
    "dev": "node scripts/gen-clientid.mjs && node scripts/gen-catalog.mjs && vite",
    "build": "node scripts/gen-clientid.mjs && node scripts/gen-catalog.mjs && vite build",
    "preview": "vite preview",
    "lint": "biome check src scripts test data vite.config.ts vitest.config.ts && npm run check:lockfile-transport",
    "lint:fix": "biome check --write src scripts test data vite.config.ts vitest.config.ts",
    "check:lockfile-transport": "node scripts/check-lockfile-transport.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@jeswr/app-shell": "workspace:*",
    "@jeswr/fetch-rdf": "^0.1.0",
    "@jeswr/solid-elements": "workspace:*",
    "@jeswr/solid-session-restore": "workspace:*",
    "@lit/react": "^1.0.8",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@rdfjs/wrapper": "^0.34.0",
    "@solid/object": "^0.6.0",
    "@solid/reactive-authentication": "^0.1.3",
    "dpop": "^2.1.1",
    "jsonld": "^9.0.0",
    "lit": "^3.3.3",
    "lucide-react": "^0.544.0",
    "n3": "^2.0.3",
    "oauth4webapi": "^3.8.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@rdfjs/types": "^2.0.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/jsonld": "^1.5.15",
    "@types/n3": "^1.26.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "jose": "^6.2.3",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "undici": "^6.27.0"
  }
}
