{
  "name": "@jeswr/pod-chat",
  "version": "0.0.1",
  "description": "Pod Chat — the typed RDF data layer for ActivityStreams 2.0 chat rooms and messages (with actionable shared-task messages) stored in a Solid pod. Experimental, AI-agent-generated.",
  "type": "module",
  "license": "MIT",
  "author": "Claude Opus 4.8 (@jeswr PSS agent)",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeswr/pod-chat.git"
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "clientid.jsonld",
    "README.md"
  ],
  "scripts": {
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "build": "tsup",
    "gate": "npm run lint && npm run typecheck && npm run coverage && npm run build"
  },
  "dependencies": {
    "@jeswr/fetch-rdf": "^0.1.0",
    "@rdfjs/wrapper": "^0.34.0",
    "@solid/object": "^0.6.0",
    "n3": "^2.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@rdfjs/types": "^2.0.1",
    "@types/n3": "^1.26.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
