# Copy to .env / .env.local. These drive the build-time clientid/callback
# generation AND the runtime SessionProvider.

# The deployment origin. The Client Identifier Document + callback.html are
# generated from this (scripts/gen-clientid.mjs), and the reactive-auth client_id
# resolves to ${APP_ORIGIN}/clientid.jsonld at runtime. Default (unset):
#   http://localhost:5173  (Vite dev server)
# Production:
#   APP_ORIGIN=https://chat.solid-test.jeswr.org
APP_ORIGIN=http://localhost:5173

# Mirror of APP_ORIGIN exposed to the client bundle (Vite only inlines VITE_*).
# Keep equal to APP_ORIGIN. Used only to label the UI; the client_id is derived
# at runtime from the actual window origin, so this is non-load-bearing for auth.
VITE_APP_ORIGIN=http://localhost:5173

# The user's HOME identity provider (Solid-OIDC issuer), shown as a hint only —
# the auth issuer always comes from the WebID profile, never this value.
VITE_HOME_IDP=https://idp.solid-test.jeswr.org
