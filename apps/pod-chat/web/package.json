{
  "name": "@jeswr/pod-chat-web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Static SPA host shell for Pod Chat — standalone Solid login + the @jeswr/pod-chat ChatRooms view, served as a static dist/ by any file server.",
  "author": "Claude Opus 4.8 (@jeswr PSS agent)",
  "license": "MIT",
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "gen:clientid": "node scripts/gen-clientid.mjs",
    "dev": "node scripts/gen-clientid.mjs && vite",
    "build": "node scripts/gen-clientid.mjs && vite build",
    "preview": "vite preview",
    "lint": "biome check src scripts test tests vite.config.ts vitest.config.ts playwright.config.ts && npm run check:lockfile-transport",
    "lint:fix": "biome check --write src scripts test tests vite.config.ts vitest.config.ts playwright.config.ts",
    "check:lockfile-transport": "node scripts/check-lockfile-transport.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@jeswr/app-shell": "git+https://github.com/jeswr/app-shell.git#5a7484df818071e24adaf4833d92f836e1c8d6e2",
    "@jeswr/fetch-rdf": "^0.1.0",
    "@jeswr/solid-elements": "git+https://github.com/jeswr/solid-elements.git#18fae0d0735a9af0cf0cafc9df5ff50c8518fb78",
    "@jeswr/solid-session-restore": "git+https://github.com/jeswr/solid-session-restore.git#f501aec",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@rdfjs/wrapper": "^0.34.0",
    "@solid/object": "^0.6.0",
    "@solid/reactive-authentication": "^0.1.3",
    "dpop": "^2.1.1",
    "lucide-react": "^0.544.0",
    "n3": "^2.0.3",
    "oauth4webapi": "^3.8.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@playwright/test": "^1.60.0",
    "@rdfjs/types": "^2.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/n3": "^1.26.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "jose": "^6.2.3",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.8"
  }
}
