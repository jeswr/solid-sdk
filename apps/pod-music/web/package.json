{
  "name": "@jeswr/pod-music-web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Static SPA host shell for Pod Music — standalone Solid login + the @jeswr/pod-music MusicLibrary, served as a static dist/ by any file server.",
  "author": "Claude Opus 4.8 (@jeswr PSS agent)",
  "license": "MIT",
  "engines": {
    "node": ">=20.12"
  },
  "scripts": {
    "gen:clientid": "node scripts/gen-clientid.mjs",
    "dev": "node scripts/gen-clientid.mjs && vite",
    "build": "node scripts/gen-clientid.mjs && vite build",
    "preview": "vite preview",
    "lint": "biome lint src scripts test tests vite.config.ts vitest.config.ts playwright.config.ts",
    "lint:fix": "biome check --write src scripts test tests vite.config.ts vitest.config.ts playwright.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@jeswr/app-shell": "github:jeswr/app-shell#7f46437612182f96a5b6726036fb555d1bdb81ec",
    "@jeswr/fetch-rdf": "^0.1.0",
    "@jeswr/solid-elements": "github:jeswr/solid-elements#f4f7a40c9cdc6854f0b45254f9632294f8810505",
    "@jeswr/solid-session-restore": "github:jeswr/solid-session-restore#0be31ede651446b9155ae823db73ddc03238a292",
    "@lit/react": "^1.0.8",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@rdfjs/wrapper": "^0.34.0",
    "@solid/object": "^0.6.0",
    "@solid/reactive-authentication": "^0.1.3",
    "dpop": "^2.1.1",
    "lucide-react": "^0.544.0",
    "lit": "^3.3.1",
    "n3": "^2.0.3",
    "oauth4webapi": "^3.8.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@rdfjs/types": "^2.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/n3": "^1.26.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "jose": "^6.2.3",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.8"
  }
}
