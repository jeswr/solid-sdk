# Disable package install/lifecycle scripts on `npm install` / `npm ci`.
#
# Suite-wide supply-chain hardening (mirrors prod-solid-server / ADR-0011):
# defends against malware shipped in a postinstall / preinstall / prepare hook
# that runs the moment a package is fetched. esbuild (via tsup/vitest) loads its
# platform binary from an optionalDependency at runtime, so it works with this
# flag; fsevents falls back to polling on macOS (dev-loop perf only).
#
# If a future dep genuinely needs its install script, the failure is loud and
# the fix is `npm rebuild --foreground-scripts <name>` in a reviewed step — not
# lifting the default.
ignore-scripts=true
