{
  "@context": [
    "https://www.w3.org/ns/solid/oidc-context.jsonld",
    {
      "fedapp": "https://w3id.org/jeswr/fed#",
      "acl": "http://www.w3.org/ns/auth/acl#",
      "ldp": "http://www.w3.org/ns/ldp#",
      "poddrive": "https://w3id.org/jeswr/pod-drive#",
      "fedapp:sector": { "@type": "@id" },
      "fedapp:access": { "@type": "@id" },
      "fedapp:consumes": { "@type": "@id" },
      "fedapp:produces": { "@type": "@id" },
      "fedapp:declaresShape": { "@type": "@id" }
    }
  ],
  "client_id": "https://pod-drive.example/clientid.jsonld",
  "client_name": "Pod Drive",
  "client_uri": "https://pod-drive.example/",
  "redirect_uris": ["https://pod-drive.example/callback.html"],
  "scope": "openid webid offline_access",
  "grant_types": ["authorization_code", "refresh_token"],
  "response_types": ["code"],
  "token_endpoint_auth_method": "none",

  "@type": "fedapp:App",
  "_comment": "No fedapp:sector — no 'documents' sector exists yet in solid-federation-vocab (media != generic files); follow-up: propose one via the fedcon documents-sector process, don't self-mint sectors/documents.",
  "fedapp:access": ["acl:Read", "acl:Write", "acl:Append"],
  "fedapp:consumes": ["ldp:Container", "ldp:Resource"],
  "fedapp:produces": ["ldp:Container", "ldp:Resource"],
  "fedapp:declaresShape": "poddrive:DriveRoot"
}
