{
  "$schema": "https://raw.githubusercontent.com/jeswr/full-solid-ecosystem/main/tracking/schema/suite.schema.json",
  "id": "pod-drive",
  "kind": "app",
  "name": "Pod Drive",
  "repo": "https://github.com/jeswr/pod-drive",
  "category": "documents",
  "maturity": "prototype",
  "visibility": "public",
  "stack": {
    "rdf": "n3 ^1.x",
    "rdf-wrapper": "@rdfjs/wrapper ^0.34.x",
    "solid-object": "@solid/object ^0.6.x",
    "fetch-rdf": "@jeswr/fetch-rdf ^0.1.x",
    "test": "vitest ^4.x",
    "lint": "@biomejs/biome ^2.x",
    "node": ">=22"
  },
  "dependsOn": ["solid-federation-vocab"],
  "federation": {
    "clientIdUrl": "https://pod-drive.example/clientid.jsonld",
    "sectors": ["documents"],
    "accessModes": ["Read", "Write", "Append"],
    "produces": ["documents"],
    "consumes": ["documents"],
    "membershipTodo": "fedapp:App publishing sector=documents + LDP Container/Resource consume/produce + poddrive:DriveRoot declaresShape; the documents sector ontology under https://w3id.org/jeswr/sectors/ is not yet frozen (interim slug). Registry membership is asserted by the registry after a signed challenge — not here."
  }
}
