{
  "@context": ["https://www.w3.org/ns/solid/oidc-context.jsonld"],
  "client_id": "https://solid-access-manager.vercel.app/clientid.jsonld",
  "client_name": "Solid Access Manager",
  "client_uri": "https://solid-access-manager.vercel.app",
  "redirect_uris": ["https://solid-access-manager.vercel.app/callback.html"],
  "post_logout_redirect_uris": ["https://solid-access-manager.vercel.app"],
  "grant_types": ["authorization_code", "refresh_token"],
  "response_types": ["code"],
  "scope": "openid webid offline_access",
  "token_endpoint_auth_method": "none"
}
