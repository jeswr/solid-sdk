# Disable package install/lifecycle scripts on `npm install` / `npm ci`.
#
# Supply-chain hardening (suite default, mirrors prod-solid-server ADR-0011):
# defends against malware that ships its payload in a postinstall/preinstall/
# prepare script that runs the moment a package is fetched. No npm lifecycle
# hook runs. If a future dep genuinely needs its install script, the failure is
# loud (the dep breaks at import) and the remediation is a controlled, reviewed
# `npm rebuild --foreground-scripts <name>` — never lifting this default.
ignore-scripts=true
