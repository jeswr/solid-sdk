# Supply-chain hardening (mirrors the package root + prod-solid-server / ADR-0011):
# no npm lifecycle hook runs on install. esbuild (via vite) loads its platform
# binary from an optionalDependency at runtime, so it works under this flag.
ignore-scripts=true

# @jeswr/solid-elements declares `n3@^1.17.0` as an OPTIONAL peer (used only by its
# `/auth` subexport's DataFactory import, which this host does not consume), while
# this host pins `n3@^2`. npm 11's strict peer resolver fails a plain `npm ci`
# (Vercel/CI) on that optional-peer mismatch even though it is harmless. Tolerate it
# so keyless `npm ci` resolves.
#
# NOTE: legacy-peer-deps also stops npm AUTO-INSTALLING peer deps, so any REQUIRED
# peer that was previously hoisted in transitively must now be an explicit dep — we
# add `@testing-library/dom` (a required peer of @testing-library/react, the source
# of `screen`/`fireEvent`) to devDependencies for this reason.
#
# The durable cross-app fix is UPSTREAM — widening the solid-elements n3 peer to
# `^1.17.0 || ^2.0.0` (prepared on solid-elements `fix/n3-peer-widen`). Once that
# lands and this host re-pins to it, this line (and the explicit @testing-library/dom)
# can be dropped and a plain keyless `npm ci` resolves with normal peer auto-install.
legacy-peer-deps=true
