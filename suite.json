    "@jeswr/federation-trust",
    "@jeswr/guarded-fetch",
    "@jeswr/matrix-chat-to-pod",
    "n8n-nodes-solid",
    "@jeswr/openclaw-memory-solid",
    "@jeswr/rdf-serialize",
    "@jeswr/rxdb-solid",
    "@jeswr/solid-a2a",
    "@jeswr/solid-agent-card",
    "solid-agent-notify",
    "@jeswr/solid-api-auth",
    "@jeswr/solid-auth-core",
    "@jeswr/solid-bookmark",
    "@jeswr/solid-chat-interop",
    "@jeswr/solid-community-feeds",
    "@jeswr/solid-components",
    "@jeswr/solid-dav-bridge",
    "@jeswr/solid-dpop",
    "@jeswr/solid-drawing",
