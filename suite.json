{
  "$schema": "https://raw.githubusercontent.com/jeswr/full-solid-ecosystem/main/tracking/schema/suite.schema.json",
  "id": "solid-sdk",
  "kind": "suite",
  "name": "Solid SDK suite workspace",
  "repo": "https://github.com/jeswr/solid-sdk",
  "category": "infrastructure",
  "maturity": "alpha",
  "visibility": "public",
  "stack": {
    "language": "TypeScript",
    "runtime": "Node >=24",
    "workspace": "pnpm + Turborepo suite workspace (packages are libraries; apps are private deployables; internal deps workspace:*)",
    "lint": "Biome",
    "test": "vitest orchestrated and cached by Turborepo",
    "publish": "per-package read-only mirror repos via scripts/mirror-publish.mjs; npm publish deferred (needs:user)"
  },
  "packages": [
    "@jeswr/agent-authz-verifier",
    "@jeswr/app-shell",
    "@jeswr/auth-solid",
    "create-solid-app",
    "@jeswr/federation-client",
