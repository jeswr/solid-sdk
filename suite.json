    "@jeswr/solid-mcp",
    "@jeswr/solid-memory",
    "@jeswr/solid-odrl",
    "solid-offline",
    "@jeswr/solid-openid-client",
    "@jeswr/solid-pod-guard",
    "@jeswr/solid-session-restore",
    "@jeswr/solid-seed",
    "@jeswr/solid-showcase-kit",
    "@jeswr/synthetic-rdf",
    "@jeswr/solid-task-model",
    "@jeswr/solid-vc",
    "@jeswr/solid-webauthn-reauth",
    "@jeswr/unstorage-solid",
    "@jeswr/y-solid"
